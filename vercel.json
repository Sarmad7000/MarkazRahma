{
  "version": 2,
  "buildCommand": "yarn vercel-build",
  "installCommand": "yarn install --frozen-lockfile || yarn install",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/build/$1"
    }
  ]
}
